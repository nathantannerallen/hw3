<h1>New Entry for <%= @place["name"] %></h1>

<form action="/places/<%= @place["id"] %>/entries" method="post">
  <input type="hidden" name="place_id" value="<%= @place["id"] %>">

  <p>
    <label for="title">Title</label><br>
    <input id="title" name="title" type="text">
  </p>

  <p>
    <label for="description">Description</label><br>
    <textarea id="description" name="description"></textarea>
  </p>

  <p>
    <label for="occurred_on">Date</label><br>
    <input id="occurred_on" name="occurred_on" type="date">
  </p>

  <p><button type="submit">Create entry</button></p>
</form>

<p><a href="/places/<%= @place["id"] %>">Back to place</a></p>
